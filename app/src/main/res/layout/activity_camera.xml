<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:contentDescription="Camera preview. Point at handwritten text to scan."
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/pageStripContainer" />

    <!-- Script selector toolbar at top -->
    <LinearLayout
        android:id="@+id/scriptToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:layout_marginTop="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Script:"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp"
            android:layout_marginEnd="8dp"
            android:importantForAccessibility="no" />

        <Spinner
            android:id="@+id/spinnerScript"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="36dp"
            android:background="@drawable/bg_spinner_dark"
            android:popupBackground="#222222"
            android:contentDescription="Select text script for recognition" />

        <TextView
            android:id="@+id/tvDetectedLang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#88FFFFFF"
            android:textSize="11sp"
            android:layout_marginStart="8dp"
            android:visibility="gone"
            android:contentDescription="Detected language" />
    </LinearLayout>

    <!-- Page count badge -->
    <TextView
        android:id="@+id/tvPageCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0 pages"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:background="#BB1A73E8"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:layout_marginTop="52dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        android:contentDescription="Number of pages scanned"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Hint bar -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Align handwritten text within frame, then tap Capture"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:background="#88000000"
        android:paddingHorizontal="14dp"
        android:paddingVertical="6dp"
        android:layout_marginBottom="8dp"
        android:importantForAccessibility="no"
        app:layout_constraintBottom_toTopOf="@id/pageStripContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Page thumbnail strip -->
    <HorizontalScrollView
        android:id="@+id/pageStripContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111111"
        android:visibility="gone"
        android:paddingVertical="8dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintBottom_toTopOf="@id/bottomControls">
        <LinearLayout
            android:id="@+id/pageStrip"
            android:layout_width="wrap_content"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:contentDescription="Thumbnail strip of scanned pages" />
    </HorizontalScrollView>

    <!-- Bottom Controls -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#000000"
        android:paddingTop="12dp"
        android:paddingBottom="28dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Capture Page"
            android:textSize="16sp"
            android:textStyle="bold"
            android:contentDescription="Capture this page"
            app:cornerRadius="28dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="46dp"
                android:text="Gallery"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:contentDescription="Add image from gallery"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:textColor="#FFFFFF"
                app:strokeColor="#FFFFFF"
                app:cornerRadius="23dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="46dp"
                android:text="Done"
                android:textSize="12sp"
                android:layout_marginEnd="6dp"
                android:enabled="false"
                android:contentDescription="Finish scanning and proceed to editor"
                app:backgroundTint="#00C853"
                app:cornerRadius="23dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="46dp"
                android:text="Cancel"
                android:textSize="12sp"
                android:contentDescription="Cancel and go back"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:textColor="#FFFFFF"
                app:strokeColor="#FFFFFF"
                app:cornerRadius="23dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Loading Overlay -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:importantForAccessibility="yes"
        android:contentDescription="Processing image, please wait">
        <ProgressBar
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="#FFFFFF"
            android:importantForAccessibility="no" />
        <TextView
            android:id="@+id/tvLoadingMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Extracting text..."
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:importantForAccessibility="no" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
