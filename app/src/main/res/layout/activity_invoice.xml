<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
 xmlns:android="http://schemas.android.com/apk/res/android"
 xmlns:app="http://schemas.android.com/apk/res-auto"
 android:layout_width="match_parent"
 android:layout_height="match_parent"
 android:background="@color/background">

 <com.google.android.material.appbar.MaterialToolbar
 android:id="@+id/toolbar"
 android:layout_width="match_parent"
 android:layout_height="?attr/actionBarSize"
 android:background="@color/accent_invoice"
 app:title="Invoice Generator"
 app:titleTextColor="#FFFFFF"
 app:navigationIcon="@drawable/ic_back"
 app:navigationIconTint="#FFFFFF"
 app:layout_constraintTop_toTopOf="parent" />

 <ScrollView
 android:layout_width="match_parent"
 android:layout_height="0dp"
 app:layout_constraintTop_toBottomOf="@id/toolbar"
 app:layout_constraintBottom_toTopOf="@id/bottomBar">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <!-- Company Info Card -->
 <androidx.cardview.widget.CardView
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginBottom="12dp"
 app:cardCornerRadius="12dp"
 app:cardElevation="3dp">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Company Details"
 android:textStyle="bold"
 android:textSize="16sp"
 android:textColor="@color/accent_invoice"
 android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Currency"
                        android:textSize="12sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_marginBottom="4dp"
                        android:importantForAccessibility="no" />

                    <Spinner
                        android:id="@+id/spinnerCurrency"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_input_cell"
                        android:paddingStart="12dp"
                        android:paddingEnd="8dp"
                        android:contentDescription="Select currency for invoice"
                        android:layout_marginBottom="12dp" />

 <com.google.android.material.textfield.TextInputLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 app:hint="Company Name">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/etCompanyName"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.textfield.TextInputLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginTop="8dp"
 style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 app:hint="Customer Name">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/etCustomerName"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal"
 android:layout_marginTop="8dp">

 <com.google.android.material.textfield.TextInputLayout
 android:layout_width="0dp"
 android:layout_weight="1"
 android:layout_marginEnd="8dp"
 style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 app:hint="Invoice No.">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/etInvoiceNo"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.textfield.TextInputLayout
 android:layout_width="0dp"
 android:layout_weight="1"
 style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 app:hint="Date">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/etDate"
 android:layout_width="match_parent"
 android:layout_height="wrap_content" />
 </com.google.android.material.textfield.TextInputLayout>

                    <!-- Tax toggle row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="12dp">

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchTax"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add Tax"
                            android:textSize="14sp"
                            android:contentDescription="Toggle tax on or off"
                            android:checked="false" />

                    </LinearLayout>

                    <!-- Tax fields (hidden by default) -->
                    <LinearLayout
                        android:id="@+id/taxFieldsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:hint="Tax Label (e.g. GST, VAT)">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTaxLabel"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text"
                                android:text="Tax"
                                android:contentDescription="Tax label name" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            app:hint="Rate (%)">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etTaxRate"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="numberDecimal"
                                android:text="0"
                                android:contentDescription="Tax rate percentage" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

 </LinearLayout>
 </LinearLayout>
 </androidx.cardview.widget.CardView>

 <!-- Raw Text -->
 <androidx.cardview.widget.CardView
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginBottom="12dp"
 app:cardCornerRadius="12dp"
 app:cardElevation="3dp">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <TextView
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Scanned Text (editable)"
 android:textStyle="bold"
 android:textSize="16sp"
 android:textColor="@color/accent_invoice"
 android:layout_marginBottom="8dp" />

 <com.google.android.material.textfield.TextInputLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
 app:hint="Scanned text">
 <com.google.android.material.textfield.TextInputEditText
 android:id="@+id/etRawText"
 android:layout_width="match_parent"
 android:layout_height="100dp"
 android:gravity="top"
 android:inputType="textMultiLine" />
 </com.google.android.material.textfield.TextInputLayout>

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnParse"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:text="[PARSE] Parse Items"
 android:layout_marginTop="8dp"
 app:cornerRadius="8dp" />
 </LinearLayout>
 </androidx.cardview.widget.CardView>

 <!-- Items List Card -->
 <androidx.cardview.widget.CardView
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:layout_marginBottom="12dp"
 app:cardCornerRadius="12dp"
 app:cardElevation="3dp">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical"
 android:padding="16dp">

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal"
 android:gravity="center_vertical">

 <TextView
 android:layout_width="0dp"
 android:layout_weight="1"
 android:layout_height="wrap_content"
 android:text="Line Items"
 android:textStyle="bold"
 android:textSize="16sp"
 android:textColor="@color/accent_invoice" />

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnAddItem"
                        android:contentDescription="Add a new line item"
 android:layout_width="wrap_content"
 android:layout_height="36dp"
 android:text="+ Add"
 android:textSize="12sp"
 app:cornerRadius="8dp"
 style="@style/Widget.Material3.Button.OutlinedButton" />
 </LinearLayout>

 <!-- Items header -->
 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="40dp"
 android:orientation="horizontal"
 android:background="@color/accent_invoice"
 android:paddingHorizontal="8dp"
 android:gravity="center_vertical"
 android:layout_marginTop="12dp">

 <TextView android:layout_width="0dp" android:layout_weight="3"
 android:layout_height="wrap_content" android:text="Item"
 android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp" />
 <TextView android:layout_width="0dp" android:layout_weight="1"
 android:layout_height="wrap_content" android:text="Qty"
 android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp"
 android:gravity="center" />
 <TextView android:layout_width="0dp" android:layout_weight="2"
 android:layout_height="wrap_content" android:text="Price"
 android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp"
 android:gravity="end" />
 <TextView android:layout_width="0dp" android:layout_weight="2"
 android:layout_height="wrap_content" android:text="Total"
 android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="13sp"
 android:gravity="end" />
 <View android:layout_width="36dp" android:layout_height="wrap_content" />
 </LinearLayout>

 <LinearLayout
 android:id="@+id/itemsContainer"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="vertical" />

 <!-- Total Section -->
 <View
 android:layout_width="match_parent"
 android:layout_height="1dp"
 android:background="@color/divider"
 android:layout_marginTop="8dp" />

 <LinearLayout
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal"
 android:paddingHorizontal="8dp"
 android:paddingTop="8dp">
 <TextView
 android:layout_width="0dp"
 android:layout_weight="1"
 android:layout_height="wrap_content"
 android:text="TOTAL"
 android:textStyle="bold"
 android:textSize="16sp" />
 <TextView
 android:id="@+id/tvTotal"
 android:layout_width="wrap_content"
 android:layout_height="wrap_content"
 android:text="Rs.0.00"
 android:textStyle="bold"
 android:textSize="16sp"
 android:textColor="@color/accent_invoice" />
 </LinearLayout>
 </LinearLayout>
 </androidx.cardview.widget.CardView>

 </LinearLayout>
 </ScrollView>

 <!-- Bottom Action Bar -->
 <LinearLayout
 android:id="@+id/bottomBar"
 android:layout_width="match_parent"
 android:layout_height="wrap_content"
 android:orientation="horizontal"
 android:padding="16dp"
 android:background="@color/surface"
 android:elevation="8dp"
 app:layout_constraintBottom_toBottomOf="parent">

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnGeneratePdf"
            android:contentDescription="Generate and save PDF invoice"
 android:layout_width="0dp"
 android:layout_weight="1"
 android:layout_height="52dp"
 android:text="[PDF] Generate PDF"
 android:textStyle="bold"
 android:layout_marginEnd="8dp"
 app:cornerRadius="12dp"
 app:backgroundTint="@color/accent_invoice" />

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnOpenFile"
            android:contentDescription="Open the saved PDF invoice"
 android:layout_width="0dp"
 android:layout_weight="1"
 android:layout_height="52dp"
 android:text="Open"
 android:layout_marginEnd="8dp"
 android:visibility="gone"
 app:cornerRadius="12dp"
 style="@style/Widget.Material3.Button.OutlinedButton" />

 <com.google.android.material.button.MaterialButton
 android:id="@+id/btnShare"
 android:contentDescription="Share the saved PDF invoice"
 android:layout_width="0dp"
 android:layout_weight="1"
 android:layout_height="52dp"
 android:text="Share"
 android:visibility="gone"
 app:cornerRadius="12dp"
 style="@style/Widget.Material3.Button.OutlinedButton" />

 </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
